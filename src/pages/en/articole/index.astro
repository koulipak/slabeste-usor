---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";

const articole = (await getCollection("articoleEn")).sort(
  (a, b) => b.data.publicat.getTime() - a.data.publicat.getTime()
);

const roHref = "https://www.slabeste-usor.ro/articole/";
const enHref = "https://www.slabeste-usor.ro/en/articole/";
const alternates = [
  { hreflang: "ro", href: roHref },
  { hreflang: "en", href: enHref },
  { hreflang: "x-default", href: roHref },
];
---

<Base
  titlu="Articles about diets and weight loss"
  descriere="Practical guides about diets, calorie deficit and healthy weight loss. Clear information, no false promises."
  lang="en"
  alternates={alternates}
>
  <nav class="breadcrumb">
    <a href="/en/">Home</a> › <span>Articles</span>
  </nav>

  <h1>Articles</h1>
  <p class="articole-intro">Practical guides about diets, calorie deficit and healthy weight loss.</p>

  <ul class="articole-lista">
    {articole.map((a) => (
      <li class="articol-card">
        <a href={`/en/articole/${a.id}/`} class="articol-card-link">
          <img class="articol-card-img" src={`/articole/img/${a.id}.jpg`} alt={a.data.titlu} width="1200" height="630" loading="lazy" />
          <div class="articol-card-text">
            <h2 class="articol-card-titlu">{a.data.titlu}</h2>
            <p class="articol-card-desc">{a.data.descriere}</p>
            <span class="articol-card-cta">Read →</span>
          </div>
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
  h1 { margin-bottom: 0.4rem; }
  .articole-intro {
    color: var(--text-soft);
    margin-bottom: 2rem;
  }
  .articole-lista {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .articol-card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    overflow: hidden;
  }
  .articol-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }
  .articol-card-link {
    display: flex;
    text-decoration: none;
    color: inherit;
  }
  .articol-card-img {
    width: 240px;
    flex-shrink: 0;
    aspect-ratio: 1200 / 630;
    object-fit: cover;
    display: block;
  }
  .articol-card-text {
    padding: 1.5rem 1.75rem;
  }
  @media (max-width: 600px) {
    .articol-card-link { flex-direction: column; }
    .articol-card-img { width: 100%; }
  }
  .articol-card-titlu {
    font-size: 1.15rem;
    margin: 0 0 0.5rem;
    color: var(--navy, var(--text));
  }
  .articol-card-desc {
    color: var(--text-soft);
    font-size: 0.93rem;
    margin: 0 0 0.9rem;
    line-height: 1.6;
  }
  .articol-card-cta {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--verde);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
