---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";
import { CATEGORII, getCategorie } from "../../data/taxonomie";
import { dificultateText } from "../../lib/format";

export async function getStaticPaths() {
  const diete = await getCollection("diete", ({ data }) => !data.draft);
  return CATEGORII.map((cat) => ({
    params: { categorie: cat.slug },
    props: {
      cat,
      diete: diete
        .filter((d) => d.data.categorie === cat.slug)
        .sort((a, b) => a.data.titlu.localeCompare(b.data.titlu, "ro")),
    },
  }));
}

const { cat, diete } = Astro.props;
---

<Base titlu={cat.nume} descriere={cat.descriere}>
  <nav class="breadcrumb"><a href="/" data-i18n="bc.acasa">Acasă</a> › {cat.nume}</nav>
  <h1>{cat.nume}</h1>
  <p class="lead">{cat.descriere}</p>

  {diete.length === 0 ? (
    <p>Încă nu avem diete publicate în această categorie. Revino curând!</p>
  ) : (
    <div class="grid">
      {diete.map((d) => (
        <article class="card">
          {d.data.imagine ? (
            <a href={`/dieta/${d.id}/`} class="card-img-link">
              <Image src={d.data.imagine} alt={d.data.imagineAlt ?? d.data.titlu} widths={[260, 520]} loading="lazy" />
            </a>
          ) : (
            <div class="card-img-ph">
              <a href={`/dieta/${d.id}/`} class="bol" aria-label={d.data.titlu}>🥗</a>
            </div>
          )}
          <div class="card-body">
            <span class="badge badge-categorie" data-cat-sg={d.data.categorie}>{getCategorie(d.data.categorie)?.numeSingular ?? ''}</span>
            <h3><a href={`/dieta/${d.id}/`} data-diet-titlu={d.id}>{d.data.titlu}</a></h3>
            <p class="card-meta" data-diet-principiu={d.id}>{d.data.principiu}</p>
            <p class="card-meta"><small><span data-i18n="card.dificultate">Dificultate:</span> <span data-dif-val={d.data.dificultate}>{dificultateText(d.data.dificultate)}</span></small></p>
          </div>
        </article>
      ))}
    </div>
  )}

  <nav class="sectiune-alte">
    <h2>Alte tipuri de diete</h2>
    {CATEGORII.filter((x) => x.slug !== cat.slug).map((x) => (
      <a href={`/categorie/${x.slug}/`} class="badge badge-categorie">{x.nume}</a>
    ))}
  </nav>
</Base>
