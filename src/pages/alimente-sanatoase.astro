---
import Base from "../layouts/Base.astro";
---

<Base
  titlu="Alimente sănătoase — magazine recomandate"
  descriere="Magazine online cu alimente sănătoase, bio și naturale. Produse recomandate pentru dietele de slăbit."
  bodyClass="pg-alimente"
>
  <div class="alim-decor" aria-hidden="true">
    <img src="/decor/avocado.png"  class="ad ad1" alt="" />
    <img src="/decor/broccoli.png" class="ad ad2" alt="" />
    <img src="/decor/capsuna.png"  class="ad ad3" alt="" />
    <img src="/decor/lamaie.png"   class="ad ad4" alt="" />
    <img src="/decor/lapte.png"    class="ad ad5" alt="" />
    <img src="/decor/mar.png"      class="ad ad6" alt="" />
    <img src="/decor/nuca.png"     class="ad ad7" alt="" />
    <img src="/decor/peste1.jpg"   class="ad ad8" alt="" />
    <img src="/decor/pui1.jpg"     class="ad ad9" alt="" />
  </div>

  <h1 data-i18n="alim.h1" style="text-align:center">Alimente Sănătoase</h1>
  <p class="lead" data-i18n="alim.lead">
    Magazine și produse pe care le recomand pentru un stil de viață sănătos.
    Găsești aici alimente bio, naturale și produse utile pentru dietele prezentate pe site.
  </p>

  <p class="afiliere-disclaimer" data-i18n-html="alim.disclaimer-html">
    ℹ️ <strong>Transparență:</strong> Unele linkuri de pe această pagină sunt linkuri de afiliere.
    Dacă cumperi prin ele, primesc un mic comision ce mă ajută să țin pagina activă,
    fără niciun cost suplimentar pentru tine.
    Recomand doar magazine și produse în care am încredere.
  </p>

  <div class="mag-grid">

    <a class="mag-card" href="https://l.profitshare.ro/l/15958014" target="_blank" rel="noopener sponsored">
      <div class="mag-icon">🌿</div>
      <h2>Vegis.ro</h2>
      <p data-i18n="alim.vegis.p">
        Magazin online specializat în alimente naturale, bio și ecologice — semințe,
        nuci, cereale integrale, superalimente, uleiuri presate la rece și produse
        fără aditivi. Ideal pentru dietele pe bază de plante, keto sau orice stil
        de viață sănătos.
      </p>
      <span class="mag-cta" data-i18n="alim.vegis.cta">Vezi produse pe Vegis.ro →</span>
    </a>

    <a class="mag-card" href="https://l.profitshare.ro/l/15958027" target="_blank" rel="noopener sponsored">
      <div class="mag-icon">🚫🍬</div>
      <h2>NoSugarShop.ro</h2>
      <p data-i18n="alim.nosugar.p">
        Magazin dedicat produselor fără zahăr și cu conținut scăzut de carbohidrați —
        ciocolată keto, paste fără carbohidrați, îndulcitori naturali, gustări fit și
        produse pentru dieta Dukan. Perfect pentru cei care urmează o dietă low-carb,
        keto sau care vor să reducă zahărul din alimentație.
      </p>
      <span class="mag-cta" data-i18n="alim.nosugar.cta">Vezi produse pe NoSugarShop.ro →</span>
    </a>

    <a class="mag-card" href="https://l.profitshare.ro/l/15958029" target="_blank" rel="noopener sponsored">
      <div class="mag-icon">🍅</div>
      <h2>Scufița Roșie</h2>
      <p data-i18n="alim.scufita.p">
        Magazin online cu produse naturale Pronat — fructe uscate, nuci, semințe,
        cereale, plante aromatice și superalimente, fără aditivi sau conservanți.
        Ingrediente curate pentru rețete sănătoase, gustări nutritive și diete
        bazate pe alimente integrale.
      </p>
      <span class="mag-cta" data-i18n="alim.scufita.cta">Vezi produse pe Scufița Roșie →</span>
    </a>

    <a class="mag-card" href="https://l.profitshare.ro/l/15958030" target="_blank" rel="noopener sponsored">
      <div class="mag-icon">🦄</div>
      <h2>Unicorn Naturals</h2>
      <p data-i18n="alim.unicorn.p">
        Magazin cu produse naturale și organice — suplimente alimentare, pudre
        funcționale, adaptogeni, superalimente și produse pentru wellness.
        Potrivit pentru cei care vor să își completeze dieta cu ingrediente
        curate, fără E-uri și fără aditivi sintetici.
      </p>
      <span class="mag-cta" data-i18n="alim.unicorn.cta">Vezi produse pe Unicorn Naturals →</span>
    </a>

    <a class="mag-card" href="https://l.profitshare.ro/l/15958037" target="_blank" rel="noopener sponsored">
      <div class="mag-icon">🧀</div>
      <h2>Parmashop.ro</h2>
      <p data-i18n="alim.parma.p">
        Magazin online cu produse alimentare de calitate — mezeluri, brânzeturi,
        conserve, condimente și specialități culinare. O sursă bună pentru
        ingrediente de calitate superioară, potrivite pentru o alimentație
        variată și echilibrată.
      </p>
      <span class="mag-cta" data-i18n="alim.parma.cta">Vezi produse pe Parmashop.ro →</span>
    </a>

    <a class="mag-card" href="https://l.profitshare.ro/l/15958033" target="_blank" rel="noopener sponsored">
      <div class="mag-icon">🌱</div>
      <h2>Minunea Naturii</h2>
      <p data-i18n="alim.minunea.p">
        Magazin online cu plante medicinale, ceaiuri, tincturi, uleiuri esențiale
        și produse naturiste. Ideal pentru completarea unei diete sănătoase cu
        remedii tradiționale și suplimente din natură, fără chimicale.
      </p>
      <span class="mag-cta" data-i18n="alim.minunea.cta">Vezi produse pe Minunea Naturii →</span>
    </a>

  </div>
</Base>

<style>
  /* ── Decor flotant alimente ── */
  .alim-decor { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
  .ad {
    position: absolute;
    object-fit: contain;
    opacity: 0.13;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.10));
  }
  /* pozitii + dimensiuni */
  .ad1  { width: 150px; bottom: 3%; right: 3%;  transform: rotate(-10deg); animation: alim-drift-a 42s ease-in-out infinite; }
  .ad2  { width: 130px; top:  8%;  left: 55%;  transform: rotate(8deg);  animation: alim-drift-b 48s ease-in-out infinite; animation-delay: -6s; }
  .ad3  { width: 120px; top: 25%;  left: 80%;  transform: rotate(-5deg); animation: alim-drift-a 44s ease-in-out infinite; animation-delay: -12s; }
  .ad4  { width: 140px; top: 35%;  left: 30%;  transform: rotate(12deg); animation: alim-drift-b 50s ease-in-out infinite; animation-delay: -4s; }
  .ad5  { width: 160px; top: 48%;  left: 68%;  transform: rotate(-8deg); animation: alim-drift-a 46s ease-in-out infinite; animation-delay: -18s; }
  .ad6  { width: 120px; top: 55%;  left:  8%;  transform: rotate(6deg);  animation: alim-drift-b 52s ease-in-out infinite; animation-delay: -9s; }
  .ad7  { width: 130px; top: 65%;  left: 45%;  transform: rotate(-12deg);animation: alim-drift-a 40s ease-in-out infinite; animation-delay: -3s; }
  .ad8  { width: 160px; top: 78%;  left: 22%;  transform: rotate(9deg);  animation: alim-drift-b 45s ease-in-out infinite; animation-delay: -15s; }
  .ad9  { width: 140px; top: 88%;  left: 72%;  transform: rotate(-6deg); animation: alim-drift-a 43s ease-in-out infinite; animation-delay: -22s; }

  @keyframes alim-drift-a {
    0%, 100% { transform: translate(0, 0) rotate(-10deg) scale(1); }
    50%       { transform: translate(12px, 16px) rotate(-8deg) scale(1.03); }
  }
  @keyframes alim-drift-b {
    0%, 100% { transform: translate(0, 0) rotate(8deg) scale(1); }
    50%       { transform: translate(-14px, 12px) rotate(10deg) scale(1.04); }
  }

  .afiliere-disclaimer {
    background: var(--galben-soft);
    border: 1.5px solid #e8d880;
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    font-size: 0.92rem;
    color: var(--text);
    margin-bottom: 2rem;
  }

  .mag-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .mag-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem;
    box-shadow: var(--shadow);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .mag-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-hover);
    text-decoration: none;
  }

  .mag-icon {
    font-size: 2.2rem;
    line-height: 1;
  }

  .mag-card h2 {
    margin: 0.25rem 0 0;
    font-size: 1.2rem;
    color: var(--navy);
  }

  .mag-card p {
    font-size: 0.92rem;
    color: var(--text-soft);
    margin: 0;
    flex: 1;
  }

  .mag-cta {
    margin-top: 0.75rem;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--navy);
    letter-spacing: 0.02em;
  }
</style>
