---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const articole = (await getCollection("articole")).sort(
  (a, b) => b.data.publicat.getTime() - a.data.publicat.getTime()
);
---

<Base
  titlu="Articole despre diete și slăbit"
  descriere="Ghiduri practice despre diete, calculul caloriilor și slăbitul sănătos. Informații clare, fără promisiuni false."
>
  <nav class="breadcrumb">
    <a href="/" data-i18n="bc.acasa">Acasă</a> › <span data-i18n="art.bc">Articole</span>
  </nav>

  <h1 data-i18n="art.h1">Articole</h1>
  <p class="articole-intro" data-i18n="art.intro">Ghiduri practice despre diete, deficit caloric și slăbit sănătos.</p>

  <ul class="articole-lista">
    {articole.map((a) => (
      <li class="articol-card">
        <a href={`/articole/${a.id}/`} class="articol-card-link">
          <img class="articol-card-img" src={`/articole/img/${a.id}.jpg`} alt={a.data.titlu} width="1200" height="630" loading="lazy" />
          <div class="articol-card-text">
            <h2 class="articol-card-titlu">{a.data.titlu}</h2>
            <p class="articol-card-desc">{a.data.descriere}</p>
            <span class="articol-card-cta" data-i18n="art.citeste">Citește →</span>
          </div>
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
  h1 { margin-bottom: 0.4rem; }
  .articole-intro {
    color: var(--text-soft);
    margin-bottom: 2rem;
  }
  .articole-lista {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .articol-card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    overflow: hidden;
  }
  .articol-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }
  .articol-card-link {
    display: flex;
    text-decoration: none;
    color: inherit;
  }
  .articol-card-img {
    width: 240px;
    flex-shrink: 0;
    aspect-ratio: 1200 / 630;
    object-fit: cover;
    display: block;
  }
  .articol-card-text {
    padding: 1.5rem 1.75rem;
  }
  @media (max-width: 600px) {
    .articol-card-link { flex-direction: column; }
    .articol-card-img { width: 100%; }
  }
  .articol-card-titlu {
    font-size: 1.15rem;
    margin: 0 0 0.5rem;
    color: var(--navy, var(--text));
  }
  .articol-card-desc {
    color: var(--text-soft);
    font-size: 0.93rem;
    margin: 0 0 0.9rem;
    line-height: 1.6;
  }
  .articol-card-cta {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--verde);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
